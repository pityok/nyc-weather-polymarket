# Server
PORT=3000
NODE_ENV=development

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Forecast job
FORECAST_CRON="*/30 * * * *"
FORECAST_JOB_ENABLED=true
EDGE_THRESHOLD=10
MIN_PROB=12

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
POLYMARKET_USE_REAL=true
BASELINE_ONLY=true

# Optional: add API keys / config later
# OPENWEATHER_API_KEY=
# POLYMARKET_API_KEY=

# Default city for ingestion and APIs
DEFAULT_CITY_ID=nyc

# Multi-city market mapping: key = "YYYY-MM-DD:cityId", value = conditionId or slug.
# Example: NYC, London, Ankara. Without an entry for a date/city → status=degraded, recommendation=no_bet.
# POLYMARKET_MARKET_IDS='{"2026-03-15:nyc":"0x...","2026-03-16:nyc":"0x...","2026-03-15:london":"0x...","2026-03-15:ankara":"0x...","2026-03-16:ankara":"0x..."}'
POLYMARKET_MARKET_IDS={}
