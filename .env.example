# Server
PORT=3000
NODE_ENV=development

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Forecast job
FORECAST_CRON="*/30 * * * *"
FORECAST_JOB_ENABLED=true
EDGE_THRESHOLD=10
MIN_PROB=12

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
POLYMARKET_USE_REAL=true
BASELINE_ONLY=true

# Optional: add API keys / config later
# OPENWEATHER_API_KEY=
# POLYMARKET_API_KEY=

# Default city for ingestion and APIs
DEFAULT_CITY_ID=nyc
